# ── Cloud9 OS — server environment ──────────────────────────────
# Copy to .env and fill in. Never commit the real .env.

# PostgreSQL
DATABASE_URL=postgres://user:pass@localhost:5432/cloud9_os

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Inbound webhook auth — generate a strong random secret, paste the SAME
# value into Helm (or whatever sends the webhooks). Sent as: Authorization: Bearer <token>
CLOUD9_WEBHOOK_TOKEN=change-me-to-a-long-random-secret

# ── Helm WMS API ────────────────────────────────────────────────
# Base = https://{your-company}.myhelm.app/public-api  (confirm your subdomain)
HELM_API_BASE=https://saas-ecommerce.myhelm.app/public-api
HELM_EMAIL=
HELM_PASSWORD=
HELM_2FA_CODE=

# ── Xero (Cloud9's own org — different from Moov) ───────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=

# ── Gmail service inbox (Cloud9's own account — different from Moov) ──
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Outbound alert email (optional) ─────────────────────────────
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=
